<mvc:View controllerName="tabelademateriais.controller.Table"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    
    <Page id="page" title="{i18n>title}">
        <VBox class="sapUiSmallMargin">

        <HBox>
            <Input id="inputQtd" placeholder="{i18n>Qtde}" width="200px"/>
            <Button text="{i18n>Filtrar}" press="onFiltrar"/>
        </HBox>

        <Table
            id="tableMateriais"
            items="{/tableMaterial}"
            selectionMode="None">

            <headerToolbar>
                <Toolbar>
                    <Title text="{i18n>Materiais}"/>
                    <ToolbarSpacer/>
                    <Button text="{i18n>Criar}" press="onAbrirDialog"/>
                </Toolbar>
            </headerToolbar>

            <columns>
                <Column><Text text="{i18n>ID}"/></Column>
                <Column><Text text="{i18n>NumMat}"/></Column>
                <Column><Text text="{i18n>Nome}"/></Column>
                <Column><Text text="{i18n>Descricao}"/></Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{ID}"/>
                        <Text text="{NumMat}"/>
                        <Text text="{Nome}"/>
                        <Text text="{Descr}"/>
                    </cells>
                </ColumnListItem>
            </items>

        </Table>
    </VBox>
    </Page>
</mvc:View>