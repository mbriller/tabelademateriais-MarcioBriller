<mvc:View controllerName="tabelademateriais.controller.Table"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    
    <Page id="page" title="{i18n>title}">
        <VBox class="sapUiSmallMargin">

        <HBox>
            <Input id="inputQtd" placeholder="Quantidade de registros" width="200px"/>
            <Button text="Filtrar" press="onFiltrar"/>
        </HBox>

        <Table
            id="tableMateriais"
            items="{/tableMaterial}"
            selectionMode="None">

            <headerToolbar>
                <Toolbar>
                    <Title text="Materiais"/>
                    <ToolbarSpacer/>
                    <Button text="Criar" press="onAbrirDialog"/>
                </Toolbar>
            </headerToolbar>

            <columns>
                <Column><Text text="ID"/></Column>
                <Column><Text text="Número Material"/></Column>
                <Column><Text text="Nome"/></Column>
                <Column><Text text="Descrição"/></Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{ID}"/>
                        <Text text="{NumMat}"/>
                        <Text text="{Nome}"/>
                        <Text text="{Descr}"/>
                    </cells>
                </ColumnListItem>
            </items>

        </Table>
    </VBox>
    </Page>
</mvc:View>